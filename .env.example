# GitHub Trending 报告平台 - 环境配置示例
# 复制此文件为 .env 并填入真实值

# 飞书应用配置
FEISHU_APP_ID=cli_a916e5b5a1b8dcd4
FEISHU_APP_SECRET=你的飞书 App Secret

# WeLink 机器人 Webhook（支持多个，用逗号分隔）
WELINK_WEBHOOK_URLS=https://open.welink.huaweicloud.com/api/werobot/v1/webhook/send?token=你的 token1&channel=standard,https://open.welink.huaweicloud.com/api/werobot/v1/webhook/send?token=你的 token2&channel=standard

# 报告 URL 配置
REPORT_BASE_URL=https://report.wenspock.site

# LLM API 配置（如果使用外部 API）
LLM_API_KEY=你的 API Key
LLM_API_URL=http://localhost:3456/analyze

{
  "name": "github-trending-reports",
  "version": "2.0.0",
  "description": "GitHub Trending 报告生成系统",
  "report": {
    "baseUrl": "${REPORT_BASE_URL}",
    "daily": {
      "enabled": true,
      "outputDir": "reports/daily",
      "template": "daily"
    },
    "weekly": {
      "enabled": true,
      "outputDir": "reports/weekly",
      "template": "weekly"
    },
    "monthly": {
      "enabled": true,
      "outputDir": "reports/monthly",
      "template": "monthly"
    },
    "index": {
      "enabled": true,
      "outputFile": "reports/index.html"
    }
  },
  "analyzer": {
    "enabled": true,
    "model": "${LLM_MODEL}",
    "temperature": "${LLM_TEMPERATURE}",
    "maxTokens": "${LLM_MAX_TOKENS}",
    "timeout": "${LLM_TIMEOUT}"
  },
  "notifier": {
    "feishu": {
      "enabled": "${FEISHU_ENABLED}",
      "appId": "${FEISHU_APP_ID}",
      "appSecret": "${FEISHU_APP_SECRET}",
      "receiveId": "${FEISHU_RECEIVE_ID}",
      "receiveIdType": "${FEISHU_RECEIVE_ID_TYPE}"
    },
    "welink": {
      "enabled": "${WELINK_ENABLED}",
      "webhookUrls": "${WELINK_WEBHOOK_URLS}"
    }
  },
  "logging": {
    "level": "info",
    "format": "colored"
  }
}

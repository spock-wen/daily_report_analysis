{
  "name": "github-trending-reports",
  "version": "2.1.0",
  "description": "GitHub Trending 报告生成系统 - 统一架构版本",
  "main": "src/index.js",
  "scripts": {
    "generate:knowledge-graph": "node scripts/generate-knowledge-graph.js",
    "generate:index": "node scripts/generate-index.js",
    "generate:wiki-index": "node scripts/generate-knowledge-graph.js",
    "run:daily": "node scripts/run-daily-workflow.js",
    "run:weekly": "node scripts/run-weekly-workflow.js",
    "run:monthly": "node scripts/run-monthly-workflow.js",
    "run:papers": "node scripts/run-papers-workflow.js",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src/ scripts/ tests/ --ext .js"
  },
  "keywords": [

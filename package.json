  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  }
